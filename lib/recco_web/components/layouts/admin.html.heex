<ReccoWeb.Navigation.admin_sidebar current_user={@current_user} />
<div class="lg:pl-64">
  <main id="main-content" class="min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <ReccoWeb.Navigation.admin_presence_indicator present_admins={assigns[:present_admins] || %{}} />
    <.flash_group flash={@flash} />
    {@inner_content}
  </main>
</div>
