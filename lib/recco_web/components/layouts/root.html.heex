<!DOCTYPE html>
<html lang={Gettext.get_locale(ReccoWeb.Gettext)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Darker+Grotesque:wght@500;700;900&family=Rubik:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script>
      // FOUC-prevention: apply .dark class before paint based on stored
      // preference or OS setting. Mirrors the toggle in assets/js/hooks/theme_toggle.js.
      (function () {
        try {
          var stored = localStorage.getItem("boardello-theme");
          var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (stored === "dark" || (stored === null && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch (_e) {}
      })();
    </script>
    <.live_title default="Boardello">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-bg text-fg antialiased font-base">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-main focus:text-main-fg focus:border-2 focus:border-border focus:rounded-base"
    >
      {gettext("Skip to content")}
    </a>
    {@inner_content}
  </body>
</html>
